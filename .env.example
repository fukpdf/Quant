# .env.example — QuantForge Environment Variable Template
#
# IMPORTANT: This file contains ONLY placeholder values.
# Never put real credentials in this file.
# Never commit a .env file with real values.
#
# In development (Replit): Use the Replit Secrets panel.
# In CI/CD: Use GitHub Actions Secrets.
# In production: Inject via environment at runtime.
#
# Copy this file to .env and fill in real values for local development only.
# The .env file is gitignored and must never be committed.

# =============================================================================
# DATABASE
# =============================================================================

# Primary PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# =============================================================================
# SUPABASE (optional — if using Supabase as managed PostgreSQL)
# =============================================================================

# Supabase project URL
SUPABASE_URL=

# Supabase anonymous key (safe for client-side use)
SUPABASE_ANON_KEY=

# Supabase service role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# CACHE / QUEUE
# =============================================================================

# Redis connection string (for caching, queues, pub/sub)
REDIS_URL=

# =============================================================================
# AI / LLM PROVIDERS (Phase 8)
# =============================================================================

# Active AI provider: openai | anthropic | gemini | mock (default: mock)
# "mock" requires no API key and returns structured placeholder responses.
# Switch providers by changing this value — no application code changes required.
AI_PROVIDER=mock

# OpenAI API key — required when AI_PROVIDER=openai
# Note: Prefer Replit AI Integrations, which don't require your own key
OPENAI_API_KEY=

# Anthropic API key — required when AI_PROVIDER=anthropic
# Note: Prefer Replit AI Integrations, which don't require your own key
ANTHROPIC_API_KEY=

# Google Gemini API key — required when AI_PROVIDER=gemini
GEMINI_API_KEY=

# AI rate limiting (optional — defaults shown)
# Maximum AI requests per minute (0 = unlimited)
AI_RATE_LIMIT_PER_MINUTE=60

# Maximum total monthly token budget (0 = unlimited)
AI_MONTHLY_TOKEN_BUDGET=1000000

# =============================================================================
# CRYPTOCURRENCY DATA PROVIDERS (Phase 1)
# =============================================================================

# Binance API credentials (read-only market data key recommended)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# CoinGecko API key (Pro tier — optional, free tier works with rate limits)
COINGECKO_API_KEY=

# CCXT unified crypto exchange library credentials (if used)
# Add per-exchange variables as needed in Phase 1

# =============================================================================
# FOREX DATA PROVIDERS (Phase 1)
# =============================================================================

# Forex data provider API key
# Options: Alpha Vantage, OANDA, Polygon.io, FXCM
FOREX_PROVIDER_API_KEY=

# OANDA-specific (if selected)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# =============================================================================
# STOCK / INDICES DATA PROVIDERS (Phase 1)
# =============================================================================

# Polygon.io API key (stocks, options, forex, crypto data)
POLYGON_API_KEY=

# Alpha Vantage API key (free tier available)
ALPHA_VANTAGE_API_KEY=

# Yahoo Finance — no API key required for basic usage

# =============================================================================
# APPLICATION SECURITY
# =============================================================================

# JWT secret for signing session tokens (min 32 chars, random)
JWT_SECRET=

# Encryption key for sensitive database columns (min 32 chars, random)
ENCRYPTION_KEY=

# Session secret for Express session middleware
SESSION_SECRET=

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node environment (development | staging | production)
NODE_ENV=development

# API server port (defaults to 5000 if not set)
PORT=5000

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Base path for the API (set by Replit proxy — do not modify in Replit)
# BASE_PATH=/api

# =============================================================================
# PAPER TRADING CONFIGURATION (Phase 5)
# =============================================================================

# Starting capital for paper trading accounts (in USD)
PAPER_TRADING_STARTING_CAPITAL=100000

# =============================================================================
# RISK ENGINE CONFIGURATION (Phase 6)
# =============================================================================

# Maximum portfolio drawdown before circuit breaker triggers (percentage)
# Example: 0.15 = 15% drawdown halts all trading
RISK_MAX_DRAWDOWN_PCT=0.15

# Maximum single-position size as percentage of portfolio
# Example: 0.05 = 5% max per position
RISK_MAX_POSITION_PCT=0.05

# =============================================================================
# MONITORING & ALERTING (Phase 10)
# =============================================================================

# Alerting webhook (e.g., Slack, Discord, or PagerDuty)
ALERT_WEBHOOK_URL=

# Sentry DSN for error tracking (Phase 10)
SENTRY_DSN=

# =============================================================================
# EXECUTION ENGINE CONFIGURATION (Phase 10)
# =============================================================================

# Execution mode: simulation | paper | live_disabled
# - simulation: instant-fill mock provider, synthetic prices (DEFAULT)
# - paper: realistic fills via live market state (requires streaming active)
# - live_disabled: OMS starts but all orders are rejected at provider level
# WARNING: "live" is NOT a valid value — the scheduler will refuse to start.
EXECUTION_MODE=simulation

# Set to false to disable the execution engine entirely on startup
EXECUTION_ENABLED=true
